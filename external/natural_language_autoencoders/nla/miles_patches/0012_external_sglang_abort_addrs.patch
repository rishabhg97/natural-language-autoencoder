+def _normalise_external_sglang_url(addr: str) -> str:
+    url = str(addr).strip()
+    if not url:
+        return ""
+    if "://" not in url:
+        url = f"http://{url}"
+    return url.rstrip("/")
+
+
+def _external_sglang_engine_urls(args: Namespace) -> list[str]:
+    raw_addrs = None
+    for attr in (
+        "rollout_external_engine_addrs",
+        "sglang_external_engine_addrs",
+        "external_engine_addrs",
+    ):
+        value = getattr(args, attr, None)
+        if value:
+            raw_addrs = value
+            break
+    if raw_addrs is None:
+        return []
+    if isinstance(raw_addrs, str):
+        raw = [part.strip() for part in raw_addrs.split(",")]
+    else:
+        raw = list(raw_addrs)
+    return [url for url in (_normalise_external_sglang_url(addr) for addr in raw) if url]
 
 
