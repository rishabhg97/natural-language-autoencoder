+    def _nla_timing_log(self, label: str, start=None, **fields) -> None:
+        if not self._nla_timing_enabled():
+            return
+        if torch.cuda.is_available():
+            torch.cuda.synchronize()
+        elapsed = None if start is None else time.perf_counter() - start
+        rank = dist.get_rank() if dist.is_initialized() else -1
+        mem_fields = {}
+        if torch.cuda.is_available():
+            device = torch.cuda.current_device()
+            gib = 1024 ** 3
+            mem_fields = {
+                "cuda_device": device,
+                "cuda_allocated_gib": round(torch.cuda.memory_allocated(device) / gib, 3),
+                "cuda_reserved_gib": round(torch.cuda.memory_reserved(device) / gib, 3),
+                "cuda_max_allocated_gib": round(torch.cuda.max_memory_allocated(device) / gib, 3),
+            }
+        payload = {"rank": rank, "label": label, **fields, **mem_fields}
+        if elapsed is not None:
+            payload["elapsed_s"] = round(elapsed, 6)
+        logger.info("[NLA TIMING] " + " ".join(f"{k}={v}" for k, v in payload.items()))
