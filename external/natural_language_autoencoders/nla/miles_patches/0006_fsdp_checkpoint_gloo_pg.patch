@@ -15,3 +15,27 @@
 logger = logging.getLogger(__name__)


+_CHECKPOINT_PROCESS_GROUP = None
+
+
+def _get_checkpoint_process_group():
+    """Use Gloo for DCP metadata collectives when training uses NCCL.
+
+    torch.distributed.checkpoint coordinates save plans with object collectives
+    before it writes shard data. On large Nano30B FSDP saves, the default NCCL
+    group can fail in scatter_object_list before any shard files are written.
+    Keep model/FSDP collectives on the default group, but route DCP metadata
+    collectives through a CPU-friendly Gloo group.
+    """
+    global _CHECKPOINT_PROCESS_GROUP
+
+    if not dist.is_available() or not dist.is_initialized() or dist.get_world_size() == 1:
+        return None
+    if dist.get_backend() != "nccl":
+        return None
+    if _CHECKPOINT_PROCESS_GROUP is None:
+        logger.info("[FSDP] Creating Gloo checkpoint process group for DCP metadata collectives.")
+        _CHECKPOINT_PROCESS_GROUP = dist.new_group(backend="gloo")
+    return _CHECKPOINT_PROCESS_GROUP
+
+
 class ModelState(Stateful):
     """Wrapper for model state only."""

